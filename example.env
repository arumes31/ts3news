# Locale for bot messages (e.g., en_US, de_DE, fr_FR, ja_JP)
LANG=en_US

TS3_HOST=your_server_ip
TS3_PORT=9987
TS3_NICKNAME=MrFree
TS3_IDENTITY=your_exported_identity_string

# Each cycle sleeps a random number of hours within this range before reconnecting.
MIN_INTERVAL_HOURS=1
MAX_INTERVAL_HOURS=12
POKE_DELAY_MS=1200

# A game may be sent to the same user again this many days after the last send
# (e.g. when the game is offered again months later). 0 = never resend.
RESEND_AFTER_DAYS=60
# Purge users (and their history) that have not connected for this many days. 0 = never.
DEAD_USER_DAYS=180

# URL shortener (optional).
REDRX_API_KEY=your_redrx_api_key

# Only poke clients with this nickname (testing). Leave unset to poke everyone.
# TS3_TARGET_NICK=Daniel

# ---- Game sources ----
# Master switch for the free game notification feature.
ENABLE_GAME_NEWS=true
ENABLE_GAMERPOWER=true
ENABLE_EPIC=true
ENABLE_REDDIT=true
# IsThereAnyDeal API key; leave empty to disable ITAD.
ITAD_API_KEY=
# Comma-separated DRM platforms to keep: steam, epic, gog.
DRM_FILTER=steam,epic

# ---- Message flavour ----
ENABLE_YOUTUBE_TRAILER=true
ENABLE_GREETINGS=true
ENABLE_HOLIDAY_THEMES=true
# Bot adopts a game-themed nickname while announcing (e.g. VaultBoy for Fallout).
DYNAMIC_NICKNAME=true
# Rename occupied channels from the 1000-name pool each cycle (needs channel-name
# modify permission; set false to leave channel names untouched).
ENABLE_CHANNEL_RENAME=true

# ---- RPG Settings ----
# Master switch for the RPG system (combat, gear, skills, pets, AH).
# If false, players only receive game news and XP/Leveling progression (if enabled).
ENABLE_RPG=true
# Base stats. Adjust these upwards if players (especially new ones) are dying too often,
# aiming for a roughly 50% win rate across your specific playerbase.
RPG_BASE_HP=100
RPG_BASE_STR=10
RPG_BASE_DEF=5

# ---- Leveling ----
# Master switch for the XP and Rank system. Works standalone (from time and game news).
ENABLE_LEVELING=true
# XP scales with the game's price. false (default): pricier games grant more XP.
# true: cheaper games grant more XP.
CHEAPER_MORE_XP=false
# Grant TS3 server groups at level milestones: "level:groupID,level:groupID".
# Requires the bot's identity to hold group-management permission. Empty = disabled.
LEVEL_GROUPS=
# Auto-create one server group per level tier (25 tiers) with a generated icon
# showing the tier number/prestige. Groups are created lazily when a user first
# reaches a tier and deleted automatically once empty. Requires the bot's identity
# to have group-create, group-assign, file-upload and icon permissions.
XP_SERVER_GROUPS=false
# Whether XP/title group names are shown next to a member's nickname in the client
# tree (i_group_show_name_in_tree): 0=hidden, 1=before the name, 2=after the name.
# A negative value leaves the permission untouched. XP groups default to 2, title
# groups to 1.
XP_GROUP_SHOW_NAME_IN_TREE=2
TITLE_GROUP_SHOW_NAME_IN_TREE=1

# ---- Client lifecycle / watchdog ----
TS3_CLIENT_PATH=/opt/ts3/ts3client_linux_amd64
# Max seconds to wait for the client to connect each cycle before the watchdog
# kills and relaunches it.
CONNECT_TIMEOUT_SEC=120

# ---- Web portal ----
# Player web portal: armoury, inventory, TFT-style auto-battler, arcade, shop,
# auction house. Each user is PM'd a personal (shortened) login link every cycle.
WEB_ENABLE=true
# Address the web server listens on (inside the container).
WEB_LISTEN_ADDR=:18081
# Public base URL used to build the per-user login links sent via PM. Set this to
# the externally reachable URL (e.g. https://rpg.example.com).
WEB_BASE_URL=http://localhost:18081
# The Abyss: an endless push-your-luck PvE dungeon that runs your real character
# through the combat engine (difficulty tiers, escrow cache, insurance, revival,
# Deep-Delver upgrades, depth leaderboards). Enabled by default.
ENABLE_ABYSS=true

# ---- Idely: idle-music subsystem ----
# A dedicated, always-on TeamSpeak client ("Idely") watches every occupied
# channel. When *all* users in a channel have been idle past IDELY_IDLE_MINUTES,
# it dispatches a TS3AudioBot sidecar (its own random-named voice client) to join
# that channel and play lo-fi music, stopping the instant anyone talks or moves.
#
# Topology note: the TeamSpeak ClientQuery plugin port (25639) is hard-coded and
# localhost-only, so Idely CANNOT share a container with the main poke bot. It
# runs as its own container (see the `ts3-idely` service) with IDELY_ONLY=1. The
# variables below are consumed by that container.
ENABLE_IDELY=false
IDELY_ONLY=false
# Idely's display name, and OPTIONALLY its own TeamSpeak identity. Leave
# IDELY_IDENTITY empty to use the ts3-idely container's own persistent client
# profile (identity kept in the idely_profile volume across restarts). Only set it
# (to a DIFFERENT identity than the poke bot) if your server enforces a minimum
# identity security level. In the ts3-idely container these map to TS3_IDENTITY /
# TS3_NICKNAME.
IDELY_IDENTITY=
IDELY_NICKNAME=Idely
# Detection tuning. "idle" = NO VOICE ACTIVITY: ClientQuery can't read other
# clients' idle time, so Idely measures quiet time itself from voice events.
IDELY_IDLE_MINUTES=15
IDELY_POLL_SECONDS=5
IDELY_ACTIVE_GRACE_SECONDS=6
# One audio bot per idle channel, spawned on demand (never idle-connected), capped here.
IDELY_MAX_BOTS=4
# Stop-on-talk (needs the IdelyTalkSensor plugin on the bot): stop when the bot
# heard voice within this many ms, then keep the channel quiet this many seconds
# before serenading again (prevents flapping while someone keeps talking).
IDELY_TALK_STOP_MS=2500
IDELY_TALK_COOLDOWN_SEC=60
# Plugin to load per spawned bot. TS3AudioBot's `plugin load` resolves by INDEX,
# so 0 = the first/only plugin. "" disables talk-stop.
IDELY_PLUGIN=0
# Restrict to specific channel ids (comma-separated); empty = all channels.
# IDELY_ONLY_CIDS=
# Extra identities to ignore during idle detection (optional). Exclusions are now
# automatic: the Idely client excludes itself, audio bots are excluded by name AND
# by learned UID, and the MAIN poke bot publishes its own UID to the shared
# database on connect so Idely excludes it too. Only add UIDs here for anything
# else you want ignored.
IDELY_EXCLUDE_UIDS=
# TS3AudioBot sidecar WebAPI. Auth is OPTIONAL: the seeded rights.toml lets Idely
# drive the in-network WebAPI anonymously (the ts3audiobot service publishes no
# ports). To require a token instead, run `!api token` in the bot and set
# IDELY_API_USER=the uid it prints, IDELY_API_TOKEN=the token.
IDELY_API_URL=http://ts3audiobot:58913
IDELY_API_USER=
IDELY_API_TOKEN=
# Optional override for the audio bot's TeamSpeak identity uid. Leave empty: Idely
# learns it automatically from live snapshots (the bots wear names from IDELY_NAMES).
IDELY_BOT_UID=
# Playback volume 0..100. Note: TS3AudioBot also clamps each song to its
# [bot.audio] volume {min,max} range, so raise that in ts3audiobot.toml too.
IDELY_VOLUME=100
# Idely builds its playlist by scanning IDELY_TRACKS_DIR (as both Idely and the
# audio bot see it: the shared /audio volume). Populate it by dropping your own
# audio files into runtime/music/ (mounted at /audio) — no download step needed.
IDELY_TRACKS_DIR=/audio
# Optional: set an explicit comma-separated track list to override the scan.
# IDELY_TRACKS=game1.mp3,game2.mp3
# Comma-separated pool of random display names for the audio bot.
# IDELY_NAMES=game.radio,Retro Vibes,Arcade Lounge,gameplay.fm

# ---- Database (Postgres) ----
DB_USER=ts3bot
DB_PASS=ts3botpass
DB_NAME=ts3news
DATABASE_URL=postgres://ts3bot:ts3botpass@db:5432/ts3news?sslmode=disable

# Google AI Studio API Key for Graphify semantic GraphRAG
GEMINI_API_KEY=

