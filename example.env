# Locale for bot messages (e.g., en_US, de_DE, fr_FR, ja_JP)
LANG=en_US

TS3_HOST=your_server_ip
TS3_PORT=9987
TS3_NICKNAME=MrFree
TS3_IDENTITY=your_exported_identity_string

# Each cycle sleeps a random number of hours within this range before reconnecting.
MIN_INTERVAL_HOURS=1
MAX_INTERVAL_HOURS=12
POKE_DELAY_MS=1200

# A game may be sent to the same user again this many days after the last send
# (e.g. when the game is offered again months later). 0 = never resend.
RESEND_AFTER_DAYS=60
# Purge users (and their history) that have not connected for this many days. 0 = never.
DEAD_USER_DAYS=180

# URL shortener (optional).
REDRX_API_KEY=your_redrx_api_key

# Only poke clients with this nickname (testing). Leave unset to poke everyone.
# TS3_TARGET_NICK=Daniel

# ---- Game sources ----
# Master switch for the free game notification feature.
ENABLE_GAME_NEWS=true
ENABLE_GAMERPOWER=true
ENABLE_EPIC=true
ENABLE_REDDIT=true
# IsThereAnyDeal API key; leave empty to disable ITAD.
ITAD_API_KEY=
# Comma-separated DRM platforms to keep: steam, epic, gog.
DRM_FILTER=steam,epic

# ---- Message flavour ----
ENABLE_YOUTUBE_TRAILER=true
ENABLE_GREETINGS=true
ENABLE_HOLIDAY_THEMES=true
# Bot adopts a game-themed nickname while announcing (e.g. VaultBoy for Fallout).
DYNAMIC_NICKNAME=true

# ---- RPG Settings ----
# Master switch for the RPG system (combat, gear, skills, pets, AH).
# If false, players only receive game news and XP/Leveling progression (if enabled).
ENABLE_RPG=true
# Base stats. Adjust these upwards if players (especially new ones) are dying too often,
# aiming for a roughly 50% win rate across your specific playerbase.
RPG_BASE_HP=100
RPG_BASE_STR=10
RPG_BASE_DEF=5

# ---- Leveling ----
# Master switch for the XP and Rank system. Works standalone (from time and game news).
ENABLE_LEVELING=true
# XP scales with the game's price. false (default): pricier games grant more XP.
# true: cheaper games grant more XP.
CHEAPER_MORE_XP=false
# Grant TS3 server groups at level milestones: "level:groupID,level:groupID".
# Requires the bot's identity to hold group-management permission. Empty = disabled.
LEVEL_GROUPS=
# Auto-create one server group per level tier (25 tiers) with a generated icon
# showing the tier number/prestige. Groups are created lazily when a user first
# reaches a tier and deleted automatically once empty. Requires the bot's identity
# to have group-create, group-assign, file-upload and icon permissions.
XP_SERVER_GROUPS=false

# ---- Client lifecycle / watchdog ----
TS3_CLIENT_PATH=/opt/ts3/ts3client_linux_amd64
# Max seconds to wait for the client to connect each cycle before the watchdog
# kills and relaunches it.
CONNECT_TIMEOUT_SEC=120

# ---- Web portal ----
# Player web portal: armoury, inventory, TFT-style auto-battler, arcade, shop,
# auction house. Each user is PM'd a personal (shortened) login link every cycle.
WEB_ENABLE=true
# Address the web server listens on (inside the container).
WEB_LISTEN_ADDR=:18081
# Public base URL used to build the per-user login links sent via PM. Set this to
# the externally reachable URL (e.g. https://rpg.example.com).
WEB_BASE_URL=http://localhost:18081

# ---- Database (Postgres) ----
DB_USER=ts3bot
DB_PASS=ts3botpass
DB_NAME=ts3news
DATABASE_URL=postgres://ts3bot:ts3botpass@db:5432/ts3news?sslmode=disable
